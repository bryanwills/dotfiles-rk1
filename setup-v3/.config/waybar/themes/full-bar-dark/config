{
    "ipc": true,
        "tooltip": true,
        "layer": "top",
        "position": "top",
        "height": 34, 
        "margin-top": 5,
        "margin-left": 5,
        "margin-right": 5,
        "spacing": 4,
        "exclusive": true,
        "reload_style_on_change": true,
    "modules-left": ["custom/launcher", "custom/sync", "custom/budget", "custom/wallpaper", "custom/keybinds", "custom/gallery"],
            "modules-center": ["hyprland/submap", "hyprland/workspaces", "wlr/taskbar"],
            "modules-right": ["cpu", "temperature", "battery", "memory", "network", "bluetooth", "custom/notification", "custom/power"],
    
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "window-rewrite": {
            "class<falkon>": "п‰Ё",       // Icon for Falkon
            "class<floorp>": "п‰©",       // Icon for Floorp
            "class<kitty>": "п„ ",        // Icon for Kitty
            "class<foot>": "п’‰",         // Icon for Foot
            "class<custom_rtm>": "п‚®",   // Icon for RTM
            "class<custom_budget>": "п…•" // Icon for Budget Buddy
       },     
        "format-icons": {
            "1": "п‰Ё", 
            "2": "п„ ",
            "3": "п‚…",
            "4": "4",
            "5": "5",
            "default": "п„‘"
        },
        "persistent-workspaces": {
            "*": 5 // This forces workspaces 1-5 to be visible on all monitors
        }
    },

    "custom/launcher": {
        "format": "Apps",
        "on-click": "rofi -show drun -theme-str 'window {location: northwest; anchor: northwest; x-offset: 10px; y-offset: 0px; width: 400px; height: 800px;}'",
        "tooltip-format": " Applications Launcher"
    },

    "custom/budget": {
        	"format": "Budget",
        	"on-click": "kitty --class budget-buddy -e python3 $HOME/custom-scripts/Budget-Buddy/budget-buddy.py"
    },
    
    "custom/gallery": {
    "format": "Gallery",
    "on-click": "swayimg --gallery ~/Pictures",
    "tooltip": false
    },
        
    "custom/keybinds": {
    "format": "Keybinds",
    "on-click": "$HOME/custom-scripts/keybinds.sh",
    "tooltip": false
    },
    
    "custom/wallpaper": {
    "format": "Themes",
    "on-click": "bash $HOME/custom-scripts/changewall.sh",
    "tooltip": false
    },

    "custom/power": {
        "format": "вЏ» ",
        "on-click": "$HOME/custom-scripts/powermenu.sh",
        "tooltip": false
    },    
    
    "custom/sync": {
    "format": "Sync",
    "return-type": "json",
    "exec": "$HOME/.local/bin/check-sync",
    "interval": 30,
    "on-click": "kitty sh -c 'zsh -i -c dotsync; exec zsh'"
    },
    
    "custom/rtm": {
        "format": "Tasks {}",  // Icon + Number
        "return-type": "json",
        "exec": "$HOME/custom-scripts/RTM/rtm.py --waybar",
        "on-click": "kitty -e python3 $HOME/custom-scripts/RTM/rtm.py", // Opens the TUI when clicked
        "on-click-right": "$HOME/custom-scripts/RTM/rtm.py -n", // Right click to force notify check
        "interval": 10, // Update every 10 seconds
        "tooltip": true
    },

    "hyprland/submap": {
        "format": "вњЊпёЏ  {}",
        "max-length": 8,
        "tooltip": false
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "cpu": {
        "interval": 1,
        "format": "п‹› {usage}%",
        "tooltip": true
    },
    "memory": {
        "interval": 5,
        "format": "пѓ‰ {percentage}%",
        "tooltip": true
    },
    "battery": {
        "states": { "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-icons": ["у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
        "tooltip-format": "<span font='JetBrains Mono 14'><b>Power State</b>\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHealth: {capacity}%</span>"
    },
    
    "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 75, // Lowered because you have no fans to save you
    "format-critical": "{temperatureC}В°C п‹‡ HOT",
    "format": "{temperatureC}В°C {icon}",
    "format-icons": ["п‹‹", "п‹‰", "п‹‡"]
    },

    "network": {
    /* Only show the icon on the bar */
    "format-wifi": "п‡« ",
    "format-ethernet": "п›ї",
    "format-disconnected": "пЄ©",
    
    /* Detailed Tooltip when you hover */
    "tooltip-format": "Network Info\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n{essid} ({signalStrength}%) п‡« \n{ifname} via {gwaddr}",
    
    /* Define which icons to use for signal strength */
    "format-icons": ["п‡«", "п‡«", "п‡«", "п‡«", "п‡«"], /* You can swap these for bars like в–‚в–„в–†в–€ if you prefer */
    
    "on-click": "nm-connection-editor" /* Optional: Opens network manager on click */
},

"bluetooth": {
    "format": "пЉ” {status}",
    "format-disabled": "пЉ” Off", // Hides it when off, or use "пЉ” Off" if you prefer
    "format-connected": "пЉ” {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    
    // LEFT CLICK: Toggles Power On/Off
    "on-click": "sh -c 'bluetoothctl show | grep -q \"Powered: yes\" && bluetoothctl power off || (rfkill unblock bluetooth && bluetoothctl power on)'",
    
    // RIGHT CLICK: Opens the Manager (just in case you need to pair)
    "on-click-right": "overskride"
}
}
