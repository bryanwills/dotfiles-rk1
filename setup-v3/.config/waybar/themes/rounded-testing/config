{
    "ipc": true,
    "tooltip": false,
    "layer": "bottom",
    "position": "top",
    "height": 26, 
    "margin-top": -1,
    "margin-left": 5,
    "margin-right": 5,
    "spacing": 4,
    "exclusive": true,
    "reload_style_on_change": true,
    "modules-center": ["hyprland/submap", "hyprland/workspaces", "wlr/taskbar"],

    "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "window-rewrite": {
        "class<falkon>": " ",       // Icon for Falkon
        "class<floorp>": " ",       // Icon for Min
        "class<kitty>": " ",        // Icon for Kitty
        "class<extraterm>": " ",        // Icon for Extraterm
        "class<custom_rtm>": "",   // Icon for RTM
        "class<custom_budget>": "" // Icon for Budget Buddy
   },     
    "format-icons": {
        "1": "󰖟 ", 
        "2": " ",
        "3": " ",
        "4": "4 ",
        "5": "5 ",
        "default": " "
    },
    "persistent-workspaces": {
        "*": 5 // This forces workspaces 1-5 to be visible on all monitors
    }
},
    
    "hyprland/submap": {
        "format": "✌️  {}",
        "max-length": 8,
        "tooltip": false
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
}
