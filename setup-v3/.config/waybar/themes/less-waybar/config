{
    "ipc": true,
    "tooltip": false,
    "layer": "bottom",
    "position": "top",
    "height": 28, 
    "margin-top": -2,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 4,
    "exclusive": true,
    "reload_style_on_change": true,
    "modules-left": ["clock"],
    "modules-right": ["cpu", "memory", "tray", "battery", "temperature"],
    "modules-center": ["hyprland/submap", "hyprland/workspaces", "wlr/taskbar"],

    "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "window-rewrite": {
        "class<falkon>": " ",       // Icon for Falkon
        "class<floorp>": " ",       // Icon for Min
        "class<kitty>": " ",        // Icon for Kitty
        "class<extraterm>": " ",        // Icon for Extraterm
        "class<custom_rtm>": "",   // Icon for RTM
        "class<custom_budget>": "" // Icon for Budget Buddy
   },     
    "format-icons": {
        "1": "󰖟 ", 
        "2": " ",
        "3": " ",
        "4": " ",
        "5": "5 ",
        "default": " "
    },
    "persistent-workspaces": {
        "*": 5 // This forces workspaces 1-5 to be visible on all monitors
    }
},
    "cpu": {
        "interval": 1,
        "format": "  {usage}%", 
        // Note: Add more {usageX} depending on your core count.
        "tooltip": true
   },
    
    "memory": {
        "interval": 30,
        "format": " {used:0.1f}G/{total:0.1f}G",
        "tooltip": true
   },
    
    "clock": {
        "format": " {:%H:%M   %d/%m}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15,
            },
            "format": "{icon}  {capacity}%",
            "format-charging": "  {capacity}%",
            "format-plugged": "  {capacity}%",
            "format-alt": "{time} {icon}",
            
            /* The icons for the battery levels (Empty -> Full) */
            "format-icons": ["", "", "", "", ""]
          
     },
            
     "temperature": {
         "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
         "input-filename": "temp1_input",
         "critical-threshold": 75, // Lowered because you have no fans to save you
         "format-critical": "{temperatureC}°C  HOT",
         "format": "{temperatureC}°C {icon}",
         "format-icons": ["", "", ""]
    },
            
    "hyprland/submap": {
        "format": "✌️  {}",
        "max-length": 8,
        "tooltip": false
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "tray": {
        "spacing": 10
    }
}
