@import "../../.cache/wal/colors-waybar.css";
* {
    font-family: "JetBrainsMono Nerd Font";
    font-size: 12px;
    border: none;
    border-radius: 0;
}

/* 1. THE MAIN BAR - Transparent so islands 'float' */
window#waybar {
    background-color: transparent;
    margin: 1px 1px 0 1px;
}

.modules-left,
.modules-center,
.modules-right {
    background-color: rgba(0, 0, 0, 0.8);
    border-left: 4px solid @color2;
    border-right: 4px solid @color2;
    border-bottom: 2px solid @color2;
    border-radius: 0px 0px 25px 25px; /* The rounded 'pill' look */
    padding: 1px 15px;
    /* top | right | bottom | left */
    margin: 0px -3px 5px -3px; 
}

/* Internal spacing for center modules */
.modules-center widget {
    margin: 0 10px; 
}

.modules-center label {
    padding: 0 0 0 5px;
    font-size: 11px;
    background-color: transparent;
}

.modules-right label {
    padding: 0 8px;
    font-size: 11px;
    background-color: transparent;
    border-right: 0px solid @color14;
    border-left: 2px solid @color14;
    border-radius: 0px 0px 0px 25px;
}

.modules-left label {
    padding: 0 4px;
    font-size: 11px;
    background-color: transparent;
    border-left: 0px solid @color14;
    border-right: 2px solid @color14;
    border-radius: 0px 25px 0px 0px;
}

/* 3. WORKSPACES ISLAND */
#workspaces {
    background: transparent;
    padding: 0 10px;
    margin: 0;
}

#workspaces button {
    padding: 0 6px;
    margin: 0 1px;
    color: #ffffff;
    background: transparent;
    font-size: 12px;
}

#workspaces button.active {
    color: #00a550;
    border-bottom: 2px solid @color2;
    border-radius: 25px;
}

#workspaces button:hover {
    background: rgba(255, 255, 255, 0.1);
    border: 0px;
    border-radius: 25px;
}

/* 5. INDIVIDUAL MODULES (Cleanup) */
#network, #bluetooth, #battery, #temperature, #tray, #custom-music, #clock, #custom-sync, #custom-gallery, #custom-wallpaper, #custom-notification, #custom-keybinds, #custom-power, #custom-rtm, #custom-budget, #submap {
    background: transparent;
    color: #ffffff;
    padding: 5px 8px;
    margin: 0;
}

#taskbar {
    background: transparent;
    padding: 0 10px;
    margin: 0;
}

#taskbar button {
    padding: 0 8px;
    color: #ffffff;
    background: transparent;
    font-size: 12px;
    border-radius: 25px;
}


#taskbar button.active {
    background-color: transparent;
    border-bottom: 2px solid @color2;
    border-radius: 25px;
}

#taskbar button:hover {
    background: rgba(255, 255, 255, 0.1);
    border: 0px;
}
#custom-launcher {
    background: transparent;
    font-size: 16px;
    color: #1e90ff;
    padding: 0 10px;
    margin: 0;
}

#custom-rtm {
    padding: 0 10px;
    color: #ffffff;
}

#custom-rtm.pending {
    border-bottom: 2px solid #fab387;
}

#custom-rtm.empty {
    color: #a6adc8;
    border-right: 1px solid #a6e3a1;
}

#custom-power {
    font-size: 14px;
	padding: 0 10px;
}

#taskbar {
	background-color: transparent;
}

#custom-notification {
	font-size: 14px;
	color: #89b4fa;
	padding: 0 10px
}

#battery.critical:not(.charging) {
    color: #f38ba8; /* Red alert color */
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

#bluetooth.connected {
    color: #89b4fa; /* Blue Accent */
}

#bluetooth.off, #bluetooth.disabled {
    color: #ff0000;
}

@keyframes blink {
    to {
        color: #000000;
    }
}

/* 6. TRAY */
#tray {
    padding-left: 5px;
}
