#!/usr/bin/env zsh

# ----------------------------------------------------------------------------------------
# MINIMALIST PASS VAULT WIDGET
# Site Search with Discrete Credentials Preview
# May 2026 v0.1.2
# ----------------------------------------------------------------------------------------

PASS_FILE="$HOME/.pass"

if [[ ! -f "$PASS_FILE" ]]; then
    mkdir -p "$(dirname "$PASS_FILE")"
    echo "site,username,password" > "$PASS_FILE"
fi

if [[ "$1" == "--add" ]]; then
    clear
    print -n "󰭟  Target Site (e.g., github.com): "
    read site
    print -n "󰋙  Username: "
    read username
    print -n "󰟵  Password: "
    read -s password
    print ""

    if [[ -z "$site" || -z "$username" || -z "$password" ]]; then
        echo "Error: All fields are required."
        exit 1
    fi

    echo "${site},${username},${password}" >> "$PASS_FILE"
    echo "󰄬  Entry saved to database."
    sleep 1
    exit 0
fi

entries=(${(f)"$(tail -n +2 "$PASS_FILE")"})

if [[ ${#entries} -eq 0 || -z "${entries[1]}" ]]; then
    echo "󰆦  Password vault is completely empty."
    read -rs "?  Press [ENTER] to exit..."
    exit 1
fi

HEADER_TEXT="
󰟵 DECENTRALIZED CRYPT VAULT v0.1.0 
 Minimalist pasword manager widget

 
"
# Use comma delimiter to isolate columns cleanly
# Show only the site name in the fuzzy list, route user and pass to the side panel
selected_line=$(print -l "${entries[@]}" | fzf \
    -d ',' \
    --with-nth=1 \
    --preview="echo -e '\n  󰋙  User: {2}\n  󰟵  Pass: '\$(sed 's/./#/g' <<< '{3}')" \
    --preview-window="right:45%:border-left" \
    --height 100% \
    --reverse \
    --border rounded \
    --margin=1,2 \
    --header-first \
    --header "$HEADER_TEXT" \
    --prompt "󰭟  Search Site: " \
)

[[ -z "$selected_line" ]] && exit 0

IFS=',' read -r site username password <<< "$selected_line"

clear
echo -e "\n  󰟵  $site"
echo -e "  ----------------------------------------"
echo -e "  [1] Copy Username  ($username)"
echo -e "  [2] Copy Password"
echo -e "  ----------------------------------------\n"
print -n "  Select option [1-2]: "
read -k 1 choice
print ""

if [[ "$choice" == "1" ]]; then
    echo "$username" | tr -d '\n' | wl-copy
    echo -e "\n  󰄬  Username copied to clipboard."
    sleep 1
elif [[ "$choice" == "2" ]]; then
    echo "$password" | tr -d '\n' | wl-copy
    echo -e "\n  󰄬  Password copied to clipboard."
    echo "  󱎫  Clearing clipboard buffers in 15 seconds..."

    (
        sleep 15
        if [[ "$(wl-paste)" == "$password" ]]; then
            wl-copy --clear
        fi
    ) &!
    sleep 1.2
fi
