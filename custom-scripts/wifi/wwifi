#!/usr/bin/env zsh

# ----------------------------------------------------------------------------------------
# WIFI CONNECTION FZF WIDGET SCRIPT
# Created by Lukas Grumlik - (Rakosn1cek)
# April 2026 v0.1.0
# ----------------------------------------------------------------------------------------

# Check for dependencies
if ! command -v nmcli &> /dev/null || ! command -v fzf &> /dev/null; then
    echo "Error: nmcli or fzf not found. Please install them to use this script."
    exit 1
fi

# Using a tab character as a delimiter to keep columns separate but easy to parse
# The --fields order for the 'cut' command later
selected_network=$(nmcli --terse --fields "SSID,BARS,SECURITY,IN-USE" device wifi list | \
    grep -v "^:" | \
    sed 's/:/\t/g' | \
    fzf --height 100% \
        --reverse \
        --border rounded \
        --margin=1,2 \
        --header "Select WiFi Network (ESC to quit)" \
        --info inline \
        --tabstop=20 \
        --color="bg+:-1,bg:-1,hl:3,fg:7,header:3,info:4,pointer:3,marker:3,prompt:3")

# Exit if no selection was made
[ -z "$selected_network" ] && exit

# Extract the SSID by taking everything before the first tab
ssid=$(echo "$selected_network" | cut -f1)

# Check if the connection profile already exists
if nmcli connection show | grep -q "$ssid"; then
    nmcli connection up "$ssid" --ask
else
    echo "New network detected: $ssid"
    read -rs -p "Enter Password: " password
    echo "" 
    nmcli device wifi connect "$ssid" password "$password"
fi
