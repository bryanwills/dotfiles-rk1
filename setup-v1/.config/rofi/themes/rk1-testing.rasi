window {
    width:            600px;
    height:           600px;
    location:         center;
    anchor:           center;
    border:           2px;
    border-color:     @grey;
    background-color: @black-80;
}

mainbox {
    /* This creates the horizontal split: buttons on left, content on right */
    orientation: horizontal;
    children:    [ "mode-switcher", "box-content" ];
}

/* Container for the search and list */
box-content {
    orientation: vertical;
    children:    [ "inputbar", "listview" ];
    background-color: transparent;
}

mode-switcher {
    orientation: vertical;
    width:       60px;
    spacing:     10px;
    padding:     10px 5px;
    background-color: rgba(255, 255, 255, 0.05);
}

button {
    padding:          10px;
    background-color: transparent;
    text-color:       @dim-white;
    font:             "JetBrainsMono Nerd Font 18"; /* Larger icons */
    horizontal-align: 0.5;
}

button selected {
    text-color:       @pale-green;
    background-color: rgba(255, 255, 255, 0.1);
    border:           0px 0px 0px 3px; /* Indicator on the left of the button */
    border-color:     @pale-green;
}
