# Kew Neon Theme
# Format: Background, Foreground, Accent, Visualizer
# --------------------------------------------------
# Deep space background
background=0d0d0d
# Soft white for text
foreground=e0e0e0
# Electric Purple for Track Name
accent=bf00ff
# Cyan to Magenta gradient for the bars
visualizer=00ffff
visualizer_top=ff00ff
# Progress bar color
progress=00ff99
