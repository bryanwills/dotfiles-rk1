/**
 * Rofi Theme: rk1-dark
 * Colors: Black borders/accents on 0.9 White
 */

* {
    /* Hardcoded White Palette */
    ghost-white:       #f8f8ff ;
    off-white:         #dddddd;
    dim-white:         #aaaaaa;
    pale-green:        #98fb98;
    grey:              #808080;
    
    /* 0.9 Opacity Black (E6 hex) */
    white-80:   rgba(255, 255, 255, 0.8); 

    background-color:  transparent;
    text-color:        @ghost-white;
    font:              "JetBrainsMono Nerd Font 11";
}

window {
    border:           2px;
    /* Border is now White */
    border-color:     @grey;
    background-color: @white-80;
    border-radius:    0px;
}

mainbox {
    children:         [ inputbar, listview ];
    background-color: inherit;
}

inputbar {
    children:         [ prompt, entry ];
    padding:          12px;
}

prompt {
    padding:          6px;
    text-color:       @off-white;
}

entry {
    placeholder:       "Search...";
    placeholder-color: @dim-white;
    padding:           6px;
    text-color:        @ghost-white;
}

listview {
    columns:          1;
    lines:            8;
    padding:          5px 5px;
    fixed-height:     true;
    dynamic:          true;
    layout:           vertical;
}

element {
    padding:          2px 10px;
    spacing:          10px;
    border-radius:    5px;
    background-color: transparent;
}

/* THE SELECTOR: Left-side 'dash' indicator */
element selected {
    /* Selector Dash is White */
    border:           0px 0px 0px 4px;
    border-color:     @pale-green; 
    
    /* Subtle highlight */
    background-color: transparent;
    text-color:       @pale-green;
}

element-icon {
    size:             25px;
}

element-text {
    vertical-align:   0.5;
    text-color:       inherit;
    highlight:        none;
}
mode-switcher {
    spacing:          0;
}

button {
    padding:          5px;
    text-color:       @wal-grey;
    vertical-align:   0.5; 
    horizontal-align: 0.5;
}

button selected {
    text-color:       @wal-accent;
}
