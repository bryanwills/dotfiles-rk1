{
    "ipc": true,
    "tooltip": false,
    "layer": "bottom",
    "position": "top",
    "height": 28, 
    "margin-top": -2,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 4,
    "exclusive": true,
    "reload_style_on_change": true,
    "modules-left": ["clock", "custom/tt", "custom/recorder"],
    "modules-right": ["cpu", "memory", "tray", "battery", "temperature"],
    "modules-center": ["hyprland/submap", "hyprland/workspaces", "wlr/taskbar"],

    "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "window-rewrite": {
        "class<falkon>": "ÔČ® ",       // Icon for Falkon
        "class<min>": "ÔČ© ",       // Icon for Min
        "class<kitty>": "ÔĄ† ",        // Icon for Kitty
        "class<extraterm>": "ÔĄ† ",        // Icon for Extraterm
        "class<custom_rtm>": "Ôāģ",   // Icon for RTM
        "class<custom_budget>": "ÔÖē" // Icon for Budget Buddy
   },     
    "format-icons": {
        "1": "ůįĖü ", 
        "2": "ÔĄ† ",
        "3": "ÔāÖ ",
        "4": "ÔĀĺ ",
        "5": "5 ",
        "default": "ÔĄĎ "
    },
    "persistent-workspaces": {
        "*": 5 // This forces workspaces 1-5 to be visible on all monitors
    }
},

    "custom/recorder": {
        "format": "{}",
        "interval": 1,
        "return-type": "json",
        "exec": "if pgrep -x wf-recorder > /dev/null; then echo '{\"text\": \"ÔÄĹ  REC\", \"class\": \"recording\"}'; else echo '{\"text\": \"ÔĎá  IDLE\", \"class\": \"idle\"}'; fi",
        "on-click": "kitty -T 'Mirec' bash -c '/home/rk1/arch-projects/MIREC/mirec'",
        "on-click-right": "pkill -SIGINT wf-recorder && rm -f /tmp/mirec.pid",
        "tooltip": false
    },

    "custom/tt": {
            "exec": "$HOME/.local/bin/tt status",
            "return-type": "json",
            "interval": 1,
            "format": "‚ŹĪ {}",
            "tooltip": false,
            "on-click": "$HOME/.local/bin/tt stop",
            "on-click-right": "notify-send 'Project Totals' \"$($HOME/.local/bin/tt log)\"",
            "signal": 1
    },
    "cpu": {
        "interval": 1,
        "format": "Ôčõ  {usage}%", 
        // Note: Add more {usageX} depending on your core count.
        "tooltip": true
   },
    
    "memory": {
        "interval": 30,
        "format": "ÔÉČ {used:0.1f}G/{total:0.1f}G",
        "tooltip": true
   },
    
    "clock": {
        "format": "ÔÄó {:%H:%M  ÔĄ≥ %d/%m}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15,
            },
            "format": "{icon}  {capacity}%",
            "format-charging": "Ôá¶  {capacity}%",
            "format-plugged": "Ôá¶  {capacity}%",
            "format-alt": "{time} {icon}",
            
            /* The icons for the battery levels (Empty -> Full) */
            "format-icons": ["ÔČĄ", "ÔČÉ", "ÔČā", "ÔČĀ", "ÔČÄ"]
          
     },
            
     "temperature": {
         "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
         "input-filename": "temp1_input",
         "critical-threshold": 75, // Lowered because you have no fans to save you
         "format-critical": "{temperatureC}¬įC Ôčá HOT",
         "format": "{temperatureC}¬įC {icon}",
         "format-icons": ["Ôčč", "ÔčČ", "Ôčá"]
    },
            
    "hyprland/submap": {
        "format": "‚úĆÔłŹ  {}",
        "max-length": 8,
        "tooltip": false
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "tray": {
        "spacing": 10
    }
}
