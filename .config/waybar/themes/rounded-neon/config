{
    "ipc": true,
        "tooltip": false,
        "layer": "top",
        "position": "top",
        "height": 32, 
        "margin-top": 5,
        "margin-left": 5,
        "margin-right": 5,
        "spacing": 4,
        "exclusive": true,
        "reload_style_on_change": true,
    "modules-left": ["custom/launcher", "custom/sync", "custom/rtm", "custom/budget", "custom/wallpaper", "custom/keybinds", "custom/gallery"],
            "modules-center": ["hyprland/submap", "clock", "hyprland/workspaces", "wlr/taskbar"],
            "modules-right": ["temperature", "battery", "network", "bluetooth", "custom/notification", "custom/power"],
    
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "window-rewrite": {
            "class<falkon>": "яЙи",       // Icon for Falkon
            "class<floorp>": "яЙй",       // Icon for Floorp
            "class<kitty>": "яДа",        // Icon for Kitty
            "class<foot>": "яТЙ",         // Icon for Foot
            "class<custom_rtm>": "яВо",   // Icon for RTM
            "class<custom_budget>": "яЕХ" // Icon for Budget Buddy
       },     
        "format-icons": {
            "1": "яЙи", 
            "2": "яДа",
            "3": "яВЕ",
            "4": "4",
            "5": "5",
            "default": "яДС"
        },
        "persistent-workspaces": {
            "*": 5 // This forces workspaces 1-5 to be visible on all monitors
        }
    },

    "custom/launcher": {
        "format": " <span color='#1e90ff'>ґ░гЗ </span>",
        "on-click": "rofi -show drun -theme-str 'window {location: northwest; anchor: northwest; x-offset: 10px; y-offset: 0px; width: 400px; height: 800px;}'",
        "tooltip-format": " Applications Launcher"
    },

    "custom/budget": {
        	"format": "Budget",
        	"on-click": "kitty --class budget-buddy -e python3 $HOME/custom-scripts/Budget-Buddy/budget-buddy.py"
    },
    
    "custom/gallery": {
    "format": "Gallery",
    "on-click": "swayimg --gallery ~/Pictures",
    "tooltip": false
    },
        
    "custom/keybinds": {
    "format": "Keybinds",
    "on-click": "$HOME/custom-scripts/keybinds.sh",
    "tooltip": false
    },
    
    "custom/wallpaper": {
    "format": "Themes",
    "on-click": "bash $HOME/custom-scripts/changewall.sh",
    "tooltip": false
    },

    "custom/power": {
        "format": " <span color='#EE4B2B'>тП╗ </span>",
        "on-click": "$HOME/custom-scripts/powermenu.sh",
        "tooltip": false
    },    
    
    "custom/sync": {
    "format": "Sync",
    "return-type": "json",
    "exec": "$HOME/.local/bin/check-sync",
    "interval": 30,
    "on-click": "foot sh -c 'zsh -i -c dotsync; exec zsh'"
    },
    
    "custom/rtm": {
        "format": "Tasks {}",  // Icon + Number
        "return-type": "json",
        "exec": "$HOME/custom-scripts/RTM/rtm.py --waybar",
        "on-click": "kitty -e python3 $HOME/custom-scripts/RTM/rtm.py", // Opens the TUI when clicked
        "on-click-right": "$HOME/custom-scripts/RTM/rtm.py -n", // Right click to force notify check
        "interval": 10, // Update every 10 seconds
        "tooltip": true
    },

    "hyprland/submap": {
        "format": "тЬМя╕П  {}",
        "max-length": 8,
        "tooltip": false
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    
    "custom/notification": {
        "tooltip": false,
        "format": " {icon} ",
        "format-icons": {
            "notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
            "none": "яВв",
            "dnd-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
            "dnd-none": "яЗ╖",
            "inhibited-notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
            "inhibited-none": "яВв",
            "dnd-inhibited-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
            "dnd-inhibited-none": "яЗ╖"
            },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    
    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    
    "battery": {
    "states": {
        "good": 95,
        "warning": 30,
        "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "яЗж  {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-alt": "{time} {icon}",
    
    /* The icons for the battery levels (Empty -> Full) */
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    
    "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 75, // Lowered because you have no fans to save you
    "format-critical": "{temperatureC}┬░C яЛЗ HOT",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["яЛЛ", "яЛЙ", "яЛЗ"]
    },

    "network": {
    /* Only show the icon on the bar */
    "format-wifi": "яЗл ",
    "format-ethernet": "яЫ┐",
    "format-disconnected": "якй",
    
    /* Detailed Tooltip when you hover */
    "tooltip-format": "{essid} ({signalStrength}%) яЗл \n{ifname} via {gwaddr}",
    
    /* Define which icons to use for signal strength */
    "format-icons": ["яЗл", "яЗл", "яЗл", "яЗл", "яЗл"], /* You can swap these for bars like тЦВтЦДтЦЖтЦИ if you prefer */
    
    "on-click": "nm-connection-editor" /* Optional: Opens network manager on click */
},

"bluetooth": {
    "format": "яКФ {status}",
    "format-on": "яКФ on",
    "format-off": "яКФ off",
    "format-disabled": "яКФ off", // Forces "disabled" to show as "off"
    "format-connected": "яКФ {num_connections}",
    "tooltip-format": "{device_enumerate}",
    "on-click": "~/custom-scripts/rofi-bluetooth.sh",
    "interval": 2
}
}
