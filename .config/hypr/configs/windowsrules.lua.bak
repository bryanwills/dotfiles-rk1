-- Window and Layer Rules for Hyprland v0.55
-- File: ~/.config/hypr/configs/windowrules.lua

-- Widgets Rules
local widgets = {
    { name = "keybinds-widget", match = { class = "keybinds" }, float = true, size = "750 650", move = "585 9", animation = "slide top" },
    { name = "aliases-widget", match = { class = "show-aliases" }, float = true, size = "750 650", move = "585 9", animation = "slide top" },
    { name = "clipbox-widget", match = { title = "clipbox-widget" }, float = true, size = "750 650", move = "585 9", animation = "slide top" },
    { name = "control-panel-widget", match = { title = "control-panel.py" }, float = true, size = "750 650", move = "585 50", animation = "slide top" },
    { name = "audio-widget", match = { title = "Audio Switcher" }, float = true, move = "710 0", size = "500 250", animation = "slide top" },
    { name = "mirec-widget", match = { title = "Mirec" }, float = true, move = "10 55", size = "500 250", animation = "slide top" },
    { name = "bt-widget", match = { class = "bt-menu" }, float = true, move = "660 0", size = "600 400", animation = "slide top" },
    { name = "wifi-widget", match = { class = "floating_wifi" }, float = true, move = "560 0", size = "700 400", animation = "slide top" },
    { name = "waybar-widget", match = { class = "changewaybar-widget.py" } },
    { name = "notif-widget", match = { class = "notif-widget.py" }, float = true, move = "800 5", size = "400 600", animation = "slide top" }
}

for _, rule in ipairs(widgets) do
    hl.window_rule(rule)
end

-- App Launcher & Clipboard
hl.window_rule({
    name = "notifications",
    match = { class = "dunst" },
    active_opacity = 0.8,
    inactive_opacity = 0.8
})

-- Music Widget
hl.window_rule({
    name = "music-player",
    match = { class = "music" },
    size = "1000 450",
    move = "0 60",
    center = true
})

-- System & Terminal Tools
hl.window_rule({
    name = "kitty",
    match = { class = "kitty" },
    border_size = 0,
    -- Fetches the variable from your wal lua export
    border_color = hl.get_var("color0")
})

-- File Managers
hl.window_rule({
    name = "file-managers",
    match = { class = "thunar|yazi" },
    animation = "fade",
    active_opacity = 1.0
})

-- Editors & Tools
hl.window_rule({
    name = "geany-rule",
    match = { class = "geany" },
    animation = "fade",
    workspace = "3"
})

hl.window_rule({
    name = "qalculate-rule",
    match = { class = "qalculate-gtk" },
    animation = "slide top",
    active_opacity = 1.0,
    size = "600 400"
})

-- Browsers
hl.window_rule({ name = "browsers", match = { class = "falcon" }, workspace = "1" })
hl.window_rule({ name = "min-browser", match = { class = "Min" }, workspace = "1", active_opacity = 1.0 })

-- System Dialogs
hl.window_rule({
    name = "save-open-rule",
    match = { title = "^.*(Save|Open).*$" },
    stay_focused = true,
    float = true,
    center = true
})

-- Custom Apps
hl.window_rule({
    name = "rtm",
    match = { class = "rtm" },
    float = true,
    size = "800 880",
    move = "550 10",
    animation = "slide top"
})

hl.window_rule({
    name = "budget-buddy",
    match = { class = "budget-buddy" },
    float = true,
    size = "740 780",
    move = "550 10",
    animation = "slide top"
})

-- Layer Rules
hl.layer_rule({
    name = "notifications",
    match = { namespace = "dunst" },
    blur = true
})

hl.layer_rule({
    name = "waybar-layer",
    match = { namespace = "waybar" },
    blur = true,
    no_anim = true,
    ignore_alpha = 0.5
})
