-- Keybindings for Hyprland v0.55
-- File: ~/.config/hypr/configs/keybinds.lua

local mainMod = "SUPER"
local altMod = "ALT"
local terminal = "kitty"
local backup_terminal = "foot"

-- Main Keybinds
hl.bind(mainMod, "Return", hl.dsp.exec(terminal), "Open Kitty")
hl.bind(mainMod .. " SHIFT", "Return", hl.dsp.exec(backup_terminal), "Opens Backup Terminal")
hl.bind(mainMod, "X", hl.dsp.killactive(), "Closes Active Window")
hl.bind(mainMod, "Space", hl.dsp.togglefloating(), "Toggle Floating Mode")
hl.bind(mainMod, "F", hl.dsp.fullscreen(1), "Active Window Fullscreen")
hl.bind(mainMod .. " SHIFT", "Q", hl.dsp.exit(), "Logout")
hl.bind(mainMod, "S", hl.dsp.exec("~/.local/bin/toggle-theme"), "Toggle D/L Mode")
hl.bind(altMod, "N", hl.dsp.exec("~/.local/bin/nightlight"), "Night Light")

-- App Launchers
hl.bind(mainMod, "D", hl.dsp.exec("pkill -f launcher-widget.py || python3 $HOME/custom-scripts/Python-Widgets/launcher-widget.py"), "App Launcher")
hl.bind(mainMod, "Y", hl.dsp.exec("kitty --class yazi -e yazi"), "Yazi in Kitty")
hl.bind(mainMod, "T", hl.dsp.exec("thunar"), "Thunar")
hl.bind(altMod, "1", hl.dsp.exec("kitty --class rtm -e python3 ~/arch-projects/RTM/rtm.py"), "RTM Task Manager")
hl.bind(altMod, "2", hl.dsp.exec("kitty --class budget-buddy -e python3 ~/arch-projects/Budget-Buddy/budget-buddy.py"), "Budget Manager")

-- Widgets
hl.bind(altMod, "A", hl.dsp.exec("kitty --class show-aliases -e $HOME/custom-scripts/Show-Aliases/show-aliases.sh"), "Opens Aliases widget")
hl.bind(altMod, "K", hl.dsp.exec("kitty --class keybinds -e $HOME/custom-scripts/Shell-Widgets/keybinds.sh"), "Opens Keybinds widget")
hl.bind(mainMod, "B", hl.dsp.exec("kitty --class bt-menu -e $HOME/custom-scripts/bluetooth/bt"), "Opens Bluetooth widget")
hl.bind(altMod, "0", hl.dsp.exec("kitty --class floating_wifi -e ~/custom-scripts/wifi/wwifi"), "Wifi FZF widget")
hl.bind(mainMod, "W", hl.dsp.exec("python3 /home/rk1/custom-scripts/Python-Widgets/changewall-widget.py"), "Wallpaper Switcher")
hl.bind(altMod, "W", hl.dsp.exec("python3 ~/custom-scripts/Python-Widgets/changewaybar-widget.py"), "Waybar Themes")
hl.bind(altMod, "M", hl.dsp.exec("kitty --class music --app-id=music kew"), "Music Player")
hl.bind(altMod, "R", hl.dsp.exec("kitty --title='Mirec' -e ~/arch-projects/MIREC/mirec"), "Open Screen Recorder")
hl.bind(altMod, "9", hl.dsp.exec("kitty --title 'Audio Switcher' -e ~/custom-scripts/Shell-Widgets/change-audio.sh"), "Change Audio widget")
hl.bind(altMod, "C", hl.dsp.exec("python3 /home/rk1/custom-scripts/Python-Widgets/clipbox-widget2.py"), "Opens Clipboard")
hl.bind(mainMod, "C", hl.dsp.exec("python3 /home/rk1/custom-scripts/Control-Panel/control-panel.py"), "Open Control Panel")

-- Navigation (Master Layout)
hl.bind(mainMod, "H", hl.dsp.movefocus("l"), "Focus Left")
hl.bind(mainMod, "L", hl.dsp.movefocus("r"), "Focus Right")
hl.bind(mainMod, "K", hl.dsp.movefocus("u"), "Focus Up")
hl.bind(mainMod, "J", hl.dsp.movefocus("d"), "Focus Down")

-- Master Layout Controls
hl.bind(altMod, "Space", hl.dsp.layoutmsg("swapwithmaster master"), "Promote to Master")
hl.bind(altMod, "J", hl.dsp.layoutmsg("cyclenext"), "Cycle Next Window")
hl.bind(altMod, "K", hl.dsp.layoutmsg("cycleprev"), "Cycle Previous Window")
hl.bind(altMod, "L", hl.dsp.layoutmsg("mfact +0.05"), "Increase Master Size")
hl.bind(altMod, "H", hl.dsp.layoutmsg("mfact -0.05"), "Decrease Master Size")
hl.bind(mainMod, "Equal", hl.dsp.layoutmsg("addmaster"), "Add Master")
hl.bind(mainMod, "Minus", hl.dsp.layoutmsg("removemaster"), "Remove Master")

-- Workspaces
for i = 1, 5 do
    hl.bind(mainMod, tostring(i), hl.dsp.workspace(tostring(i)), "Go to Workspace " .. i)
    hl.bind(mainMod .. " SHIFT", tostring(i), hl.dsp.movetoworkspace(tostring(i)), "Move Window to Workspace " .. i)
end

-- Screenshots
hl.bind(mainMod, "Print", hl.dsp.exec([[slurp -b 00000000 -c ffff00 -w 1 | xargs -I {} sh -c "sleep 0.2 && grim -g '{}' ~/Pictures/Screenshots/\$(date +%Y%m%d_%H%M%S).png" && notify-send "Screenshot Captured"]]), "Select Area Screenshot")
hl.bind("", "Print", hl.dsp.exec("grim ~/Pictures/Screenshots/$(date +%Y%m%d_%H%M%S).png"), "Full Screen Screenshot")

-- Hardware Keys (Repeating/Locked)
hl.bindel("", "XF86AudioRaiseVolume", hl.dsp.exec("wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"), "Raise Volume")
hl.bindel("", "XF86AudioLowerVolume", hl.dsp.exec("wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"), "Lower Volume")
hl.bindel("", "XF86MonBrightnessUp", hl.dsp.exec("brightnessctl set 5%+"), "Brightness Up")
hl.bindel("", "XF86MonBrightnessDown", hl.dsp.exec("brightnessctl set 5%-"), "Brightness Down")

-- Resize Mode (Submap)
hl.bind(mainMod, "R", hl.dsp.submap("resize"), "Enter Resize Mode")

hl.submap("resize", {
    hl.binde("", "right", hl.dsp.resizeactive("10 0"), "Resize Right"),
    hl.binde("", "left", hl.dsp.resizeactive("-10 0"), "Resize Left"),
    hl.binde("", "up", hl.dsp.resizeactive("0 -10"), "Resize Up"),
    hl.binde("", "down", hl.dsp.resizeactive("0 10"), "Resize Down"),
    hl.bind("", "escape", hl.dsp.submap("reset"), "Exit Resize Mode"),
    hl.bind("", "return", hl.dsp.submap("reset"), "Exit Resize Mode"),
})

-- Mouse Binds
hl.bindm(mainMod, "mouse:272", hl.dsp.movewindow())
hl.bindm(mainMod, "mouse:273", hl.dsp.resizewindow())
