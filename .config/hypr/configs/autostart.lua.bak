-- Autostart Configuration for Hyprland v0.55
-- File: ~/.config/hypr/configs/autostart.lua

-- 1. Core System & Polkit
-- We use [[]] for long strings to handle complex shell commands easily
hl.dsp.exec_once("dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP")
hl.dsp.exec_once("systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP")
hl.dsp.exec_once("/usr/lib/polkit-kde-authentication-agent-1")

-- 2. Waybar Setup
hl.dsp.exec_once("waybar")

-- 3. Theme & Wallpaper
-- In Lua, we can concatenate strings or use logic for pathing if needed
hl.dsp.exec_once("awww-daemon && awww img $(cat ~/.cache/wal/wal)")
hl.dsp.exec_once("wal -R")
hl.dsp.exec_once("dunst")

-- 4. Hardware & Utilities
-- Handling the brightness from your cache file
hl.dsp.exec_once("brightnessctl set $(cat ~/.cache/brightness_level)")

-- Clipboard management
hl.dsp.exec_once("bash ~/.config/hypr/scripts/cliphist-start.sh")
hl.dsp.exec_once("wl-paste --type text --watch cliphist store -max-items 200")
hl.dsp.exec_once("wl-paste --type image --watch cliphist store -max-items 200")
